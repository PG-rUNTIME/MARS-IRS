# Copy to .env and adjust
DEBUG=True
SECRET_KEY=your-secret-key

# PostgreSQL
DB_NAME=ir_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Requisition notification emails (local Django run). Docker: see docker-compose.yml.
FRONTEND_BASE_URL=http://localhost:5174
REQUISITION_EMAIL_SYSTEM_NAME=MARS Internal Requisition System

# Optional: rotating application log file (default: <backend>/logs/mars_irs.log)
# LOG_DIR=/var/log/mars_irs
# LOG_LEVEL=INFO
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=7
