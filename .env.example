# Copy this file to .env.local and set VITE_API_BASE to your backend URL.
# Without this set, the app has no API connection and all data is lost on refresh.
#
# Docker (same host): leave empty to use relative /api/ (nginx or compose proxy).
# Or set to backend URL, e.g.:
# VITE_API_BASE=http://localhost:8001

# Docker Compose: copy docker.env.example → .env here for FRONTEND_BASE_URL / REQUISITION_EMAIL_SYSTEM_NAME.
