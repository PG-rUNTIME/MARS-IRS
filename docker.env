# Copy to ".env" in this project root (same folder as docker-compose.yml).
# Docker Compose loads .env automatically and substitutes into the backend service.
#
# After editing: docker compose up --build -d

# Public URL of the web app (no trailing slash). Used in emails: {FRONTEND_BASE_URL}/login
FRONTEND_BASE_URL=http://localhost:5174

# Optional — text shown above the requisition summary table in notification emails
REQUISITION_EMAIL_SYSTEM_NAME=MARS Internal Requisition System

# Production example:
# FRONTEND_BASE_URL=https://irs.yourcompany.com
# REQUISITION_EMAIL_SYSTEM_NAME=MARS Internal Requisition System
